@model MediaTracker.Pages.Shared.Components.AddMediaViewModel

<dialog id="add-dialog">
    <div class="dialog-inner">
        <div class="dialog-header">
            <span class="dialog-title">Add Media</span>
            <button type="button" class="dialog-close" onclick="document.getElementById('add-dialog').close()">&#x2715;</button>
        </div>
        <form method="post" asp-page-handler="Add" novalidate>
            <input type="hidden" name="sort" value="@Model.Filter.Sort" />
            <input type="hidden" name="dir" value="@Model.Filter.Dir" />
            <input type="hidden" name="type" value="@Model.Filter.Type" />
            @{
                var globalErrors = ViewData.ModelState[string.Empty]?.Errors;
            }
            @if (globalErrors?.Count > 0)
            {
                <div class="alert alert-danger">
                    @foreach (var e in globalErrors)
                    {<div>@e.ErrorMessage</div>}
                </div>
            }
            <div class="form-group">
                <label asp-for="NewTitle">Title</label>
                <input asp-for="NewTitle" type="text" placeholder="e.g. Dune: Part Two" />
                <span asp-validation-for="NewTitle" class="validation-message"></span>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="NewType">Type</label>
                    <select asp-for="NewType" id="add-type-select" onchange="updateStatusLabels(this.value)">
                        <option value="">Select Type</option>
                        <option value="1">Movie</option>
                        <option value="2">TV Show</option>
                        <option value="3">Game</option>
                    </select>
                    <span asp-validation-for="NewType" class="validation-message"></span>
                </div>
                <div class="form-group">
                    <label asp-for="NewReleaseDate">Release Date</label>
                    <input asp-for="NewReleaseDate" type="date" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group" style="flex: 1;">
                    <label asp-for="NewStatus">Status</label>
                    <select asp-for="NewStatus">
                        <option value="1" id="opt-plan">Plan to Watch</option>
                        <option value="2" id="opt-watching">Watching</option>
                        <option value="3" id="opt-completed">Completed</option>
                    </select>
                </div>
                <div class="form-group" style="flex: 1;">
                    <label asp-for="NewRating">Rating (1-10)</label>
                    <input asp-for="NewRating" type="number" min="1" max="10" placeholder="Optional" />
                </div>
            </div>
            <div class="dialog-actions">
                <button type="button" class="btn btn-ghost" onclick="document.getElementById('add-dialog').close()">Cancel</button>
                <button type="submit" class="btn btn-primary">Add</button>
            </div>
        </form>
    </div>
</dialog>

<script>
    function updateStatusLabels(val) {
        const isGame = val === '3';
        document.getElementById('opt-plan').textContent = isGame ? 'Plan to Play' : 'Plan to Watch';
        document.getElementById('opt-watching').textContent = isGame ? 'Playing' : 'Watching';
        document.getElementById('opt-completed').textContent = isGame ? 'Played' : 'Completed';
    }
</script>